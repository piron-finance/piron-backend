# ============================================================================
# Piron Finance Backend - PRODUCTION Environment
# ============================================================================
# ⚠️  CAUTION: Production configuration - handle with care
# This connects to production Supabase and uses Base Mainnet

NODE_ENV=production

# ============================================================================
# DATABASE - SUPABASE PRODUCTION PROJECT
# ============================================================================
# Create a separate Supabase project for production: piron-prod
DATABASE_URL="postgresql://postgres.[PROD_PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROD_PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# ============================================================================
# APPLICATION
# ============================================================================
PORT=3008
API_URL=https://api.piron.finance
CORS_ORIGIN=https://app.piron.finance,https://piron.finance

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Use strong, unique secrets for production!
JWT_SECRET=generate-a-strong-64-char-secret
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=generate-another-strong-64-char-secret
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# BLOCKCHAIN - BASE MAINNET
# ============================================================================
ACTIVE_CHAIN_ID=8453
BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
BASE_MAINNET_CHAIN_ID=8453

# ============================================================================
# REDIS (Railway Redis or external)
# ============================================================================
REDIS_HOST=your-prod-redis.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# INDEXER
# ============================================================================
GOLDSKY=your-goldsky-api-key
INDEXER_MAX_BLOCK_RANGE=2000
