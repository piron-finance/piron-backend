# ============================================================================
# Piron Finance Backend - STAGING Environment
# ============================================================================
# Copy to .env.staging and fill in values
# This connects to staging Supabase and uses Base Sepolia testnet

NODE_ENV=staging

# ============================================================================
# DATABASE - SUPABASE STAGING PROJECT
# ============================================================================
# Create a separate Supabase project for staging: piron-staging
DATABASE_URL="postgresql://postgres.[STAGING_PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[STAGING_PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# ============================================================================
# APPLICATION
# ============================================================================
PORT=3008
API_URL=https://piron-staging.up.railway.app
CORS_ORIGIN=https://staging.piron.finance,http://localhost:3001,http://localhost:3003

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
JWT_SECRET=staging-secret-change-this-abc123
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=staging-refresh-secret-xyz789
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# BLOCKCHAIN - BASE SEPOLIA (TESTNET)
# ============================================================================
ACTIVE_CHAIN_ID=84532
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
BASE_SEPOLIA_CHAIN_ID=84532

# ============================================================================
# REDIS (Railway Redis or external)
# ============================================================================
REDIS_HOST=your-staging-redis.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# INDEXER
# ============================================================================
GOLDSKY=your-goldsky-api-key
INDEXER_MAX_BLOCK_RANGE=2000
